{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@ts-cloud/aws-types": ["../aws-types/dist"],
      "@ts-cloud/aws-types/*": ["../aws-types/dist/*"],
      "@ts-cloud/core": ["../core/dist"],
      "@ts-cloud/core/*": ["../core/dist/*"]
    },
    "types": [
      "bun"
    ],
    "isolatedDeclarations": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "test/outputs"
  ]
}
