{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "paths": {
      "@ts-cloud/aws-types": [
        "../aws-types/dist"
      ],
      "@ts-cloud/aws-types/*": [
        "../aws-types/dist/*"
      ],
      "@ts-cloud/core": [
        "../core/dist"
      ],
      "@ts-cloud/core/*": [
        "../core/dist/*"
      ]
    },
    "types": [
      "bun"
    ],
    "declaration": true,
    "noEmit": false,
    "outDir": "./dist",
    "isolatedDeclarations": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "test/outputs"
  ]
}
