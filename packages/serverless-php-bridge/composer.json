{
  "name": "tscloud/serverless",
  "description": "ts-cloud serverless runtime bridge for running Laravel on AWS Lambda (a laravel/vapor-core replacement)",
  "type": "library",
  "license": "MIT",
  "keywords": ["laravel", "serverless", "lambda", "aws", "ts-cloud"],
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/queue": "^10.0|^11.0|^12.0",
    "illuminate/console": "^10.0|^11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "TsCloud\\Serverless\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "TsCloud\\Serverless\\ServerlessServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable"
}
