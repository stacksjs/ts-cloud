{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "rootDir": "./src",
    "paths": {
      "@ts-cloud/aws-types": [
        "../aws-types/dist/index.d.ts"
      ],
      "@ts-cloud/aws-types/*": [
        "../aws-types/dist/*"
      ]
    },
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist"
  },
  "include": [
    "src/**/*",
    "src/**/*.json"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
